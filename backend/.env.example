# Fantasy Baseball Backend Environment Variables

# Database
DATABASE_URL=sqlite+aiosqlite:///./fantasy_baseball.db

# ESPN Fantasy API Credentials (optional - for private leagues)
# For public leagues, these can be left empty
# To get these values:
# 1. Login to ESPN Fantasy
# 2. Open browser dev tools (F12)
# 3. Go to Application/Storage > Cookies
# 4. Copy espn_s2 and SWID values
ESPN_S2=
ESPN_SWID=

# ESPN Leagues (comma-separated for multiple)
ESPN_LEAGUE_IDS=12345,67890
ESPN_LEAGUE_TYPES=redraft,redraft
ESPN_LEAGUE_YEAR=2025

# Fantrax Dynasty Leagues
FANTRAX_LEAGUE_IDS=abc123,def456
FANTRAX_LEAGUE_TYPES=dynasty,dynasty
FANTRAX_SESSION=

# ETL Database Path (defaults to Pi path if not set)
# FANTASY_DB_PATH=/path/to/fantasy_baseball.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Rate Limiting (seconds between API calls)
RATE_LIMIT_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
