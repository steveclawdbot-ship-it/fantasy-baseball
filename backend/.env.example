# Fantasy Baseball Backend Environment Variables

# Database
DATABASE_URL=sqlite+aiosqlite:///./fantasy_baseball.db

# ESPN Fantasy API Credentials (optional - for private leagues)
# For public leagues, these can be left empty
# To get these values:
# 1. Login to ESPN Fantasy
# 2. Open browser dev tools (F12)
# 3. Go to Application/Storage > Cookies
# 4. Copy espn_s2 and SWID values
ESPN_S2=
ESPN_SWID=

# Default ESPN League (for testing)
ESPN_LEAGUE_ID=
ESPN_LEAGUE_YEAR=2025

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Rate Limiting (seconds between API calls)
RATE_LIMIT_SECONDS=1.0

# Logging
LOG_LEVEL=INFO
